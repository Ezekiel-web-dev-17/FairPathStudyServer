datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  ADMIN
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  VERIFIED
  REJECTED
  FLAGGED
  NEEDS_DOCUMENT
  ACCEPTED
}

model User {
  id                       String        @id @default(uuid())
  email                    String        @unique
  passwordHash             String
  role                     Role          @default(STUDENT)
  firstName                String?
  lastName                 String?
  countryOfOrigin          String?
  targetDestinations       String[]
  academicData             Json?         // Stores GPA, test scores (SAT/ACT/IELTS), current level
  preferences              Json?         // Stores budget, desired majors, campus setting
  profileCompletionPercent Int           @default(0)
  isVerified               Boolean       @default(false)
  verificationCode         String?       @unique
  verificationCodeExpires  DateTime?
  marketingOptIn           Boolean       @default(true) @map("marketing_opt_in") @db.Boolean
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  savedMatches             SavedMatch[]
  applications             Application[]
  universityMatchScores    UniversityMatchScore[]
}

model University {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  locationCity    String
  locationCountry String
  rankingGlobal   Int?
  rankingNational Int?
  tuitionMin      Float
  tuitionMax      Float
  setting         String        // URBAN, SUBURBAN, RURAL
  type            String        // PUBLIC, PRIVATE
  acceptanceRate  Float?
  studentBodySize Int?
  description     String        @db.Text
  featuredImage   String?
  departments     String[]
  details         Json?         // Holds structured JSON for Academics, Campus Life, Admissions
  isFeatured      Boolean       @default(false)
  isPartner       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  applications    Application[]
  matchScores     UniversityMatchScore[]
}

model Scholarship {
  id                  String   @id @default(uuid())
  title               String
  provider            String
  amountType          String   // Fixed, Range, Full Tuition
  amountValue         Float?
  amountMaxValue      Float?
  deadline            DateTime
  category            String   // Merit, Need-based, STEM, etc.
  eligibilityCriteria String   @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SavedMatch {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchType String   // UNIVERSITY or SCHOLARSHIP
  matchId   String   // Reference to University or Scholarship ID
  savedAt   DateTime @default(now())

  @@unique([userId, matchType, matchId])
}

model Application {
  id           String            @id @default(uuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  universityId String
  university   University        @relation(fields: [universityId], references: [id], onDelete: Cascade)
  programId    String?           // The course or department applied to
  status       ApplicationStatus @default(DRAFT)
  deadline     DateTime
  documents    String[]          // Array of file URLs/references
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

// Persisted match score for a user–university pair.
// Recalculated on every call to GET /matches or GET /matches/all.
model UniversityMatchScore {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  matchScore   Int
  reasons      String[]
  warnings     String[]
  calculatedAt DateTime   @default(now())

  @@unique([userId, universityId])
  @@index([userId])
}

model UserOnboarding {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.VarChar(255)
  
  // Step 1: Personal Profile
  fullName        String?  @map("full_name") @db.VarChar(255)
  dob             DateTime? @map("dob") @db.Date
  currentCountry  String?  @map("current_country") @db.VarChar(100)
  nationality     String?  @map("nationality") @db.VarChar(100)
  visaHistory     Boolean?   @map("visa_history") @db.Boolean
  
  // Step 2: Academic & Budget
  degreeLevel     String?  @map("degree_level") @db.VarChar(100)
  intendedMajor   String?  @map("intended_major") @db.VarChar(100)
  gpa             String?  @map("gpa") @db.VarChar(50)
  annualBudget    Decimal?  @map("annual_budget") @db.Decimal(12, 2)
  financialAid    String?  @map("financial_aid") @db.VarChar(100)
  destinations    String[] @map("destinations")
  
  // Step 3: Testing & Professional
  englishTest     String?  @map("english_test") @db.VarChar(50)
  englishScore    String?  @map("english_score") @db.VarChar(50)
  academicTest    String?  @map("academic_test") @db.VarChar(50)
  academicScore   String?  @map("academic_score") @db.VarChar(50)
  extracurriculars String[] @map("extracurriculars")
  workExperience  String?  @map("work_experience") @db.VarChar(100)
  industry        String?  @map("industry") @db.VarChar(100)
  
  // Step 4: Consent & Auditing
  consent         Boolean  @default(false)
  isCompleted     Boolean @default(false) @map("is_completed") @db.Boolean
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([userId])
  @@map("user_preferences")
}
